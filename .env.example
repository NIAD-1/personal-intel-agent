# AI
GOOGLE_API_KEY=
AI_MODEL=gemini-1.5-flash
TAVILY_API_KEY=

# Server
PORT=3010
ADMIN_API_KEY=change-me

# WhatsApp bridge
BRIDGE_SECRET=local_dev_secret_123
WHATSAPP_BRIDGE_URL=http://localhost:8002/send

# Where scheduled briefs should be sent.
# Can be a phone number, a full WhatsApp JID, or a group JID once the bridge has seen it.
BRIEFING_RECIPIENT=

# Scheduling
ENABLE_DAILY_BRIEFING=false
BRIEFING_HOUR_UTC=7
BRIEFING_INTERVAL_SECONDS=

# Personalization
BRIEFING_NAME=Morning Brief
INTERESTS=AI,Technology,Business Africa,Finance,Sports,Travel,Relocation,Nigeria,Startups
BLOCKED_KEYWORDS=

